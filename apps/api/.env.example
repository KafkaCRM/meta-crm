# Database
DATABASE_URL="postgresql://user:password@localhost:5432/metacrm?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Secrets Backend: "env" for local dev, "vault" for production
SECRETS_BACKEND="env"

# Vault (only if SECRETS_BACKEND=vault)
# VAULT_URL="http://localhost:8200"
# VAULT_TOKEN="replace-with-vault-token"

# App
PORT=3000
NODE_ENV=development
