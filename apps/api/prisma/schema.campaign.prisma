model Campaign {
  id            String    @id @default(cuid())
  tenant_id     String
  branch_id     String
  vertical_id   String
  pipeline_id   String
  name          String
  status        String    @default("draft")
  channel       String
  start_date    DateTime
  end_date      DateTime?
  target_leads  Int?
  utm_source    String?
  utm_medium    String?
  utm_campaign  String?
  attributes    Json      @default("{}")
  created_by    String
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  pipeline      PipelineDefinition @relation(fields: [pipeline_id], references: [id])
  vertical      Vertical           @relation(fields: [vertical_id], references: [id])
  intakeRoutes  IntegrationIntakeRoute[]

  @@index([tenant_id, status])
  @@index([tenant_id, vertical_id])
  @@index([tenant_id, pipeline_id])
  @@index([tenant_id, channel])
  @@index([tenant_id, created_at])
  @@index([tenant_id, utm_campaign])
}
