model PipelineDefinition {
  id          String @id @default(cuid())
  tenant_id   String
  name        String
  entity_type String
  vertical_id String?

  tenant        Tenant              @relation(fields: [tenant_id], references: [id])
  stages        PipelineStage[]
  transitions   PipelineTransition[]
  cases         Case[]
  leads         Lead[]
  campaigns     Campaign[]
}

model PipelineStage {
  id                     String @id @default(cuid())
  pipeline_definition_id String
  name                   String
  order                  Int
  entry_criteria         Json   @default("[]")
  sla_hours              Int?
  terminal_outcome       String? // "won" | "lost" | null

  pipelineDefinition PipelineDefinition @relation(fields: [pipeline_definition_id], references: [id])
}

model PipelineTransition {
  id                     String @id @default(cuid())
  pipeline_definition_id String
  from_stage_id          String
  to_stage_id            String
  triggers               Json   @default("[]")

  pipelineDefinition PipelineDefinition @relation(fields: [pipeline_definition_id], references: [id])
}

model AutomationWorkflow {
  id            String   @id @default(cuid())
  tenant_id     String
  name          String
  description   String?
  trigger_event String   // e.g. "Party:create", "Case:update", etc.
  flow_json     Json     // Holds steps, conditions, actions, and connections
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id, trigger_event])
}
