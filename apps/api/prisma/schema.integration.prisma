model IntegrationConfig {
  id              String   @id @default(cuid())
  tenant_id       String
  provider        String
  config_json     Json     @default("{}")
  credentials_ref Json     @default("{}")
  enabled         Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, provider])
}

model WebhookSubscription {
  id         String   @id @default(cuid())
  tenant_id  String
  url        String
  event      String
  secret_ref String
  enabled    Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])
}

// ─── Secure Credentials Vault (Phase 2) ──────────────────────────────────────

/// Stores AES-256-GCM encrypted API keys and OAuth tokens for integrations.
/// Each row holds exactly one credential set per tenant per extension.
/// cipher_text: base64-encoded ciphertext
/// iv: base64-encoded initialization vector (12 bytes for GCM)
/// tag: base64-encoded GCM authentication tag (16 bytes)
model SecureCredential {
  id           String   @id @default(cuid())
  tenant_id    String
  extension_id String
  cipher_text  String
  iv           String
  tag          String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  tenant    Tenant            @relation(fields: [tenant_id], references: [id])
  extension ExtensionRegistry @relation(fields: [extension_id], references: [id])

  @@unique([tenant_id, extension_id])
  @@index([tenant_id])
}

