model Tenant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  industry    String
  config_json Json     @default("{}")
  schema_name String?
  status      String   @default("active")
  created_at  DateTime @default(now())

  branches               Branch[]
  verticals              Vertical[]
  users                  User[]
  roles                  Role[]
  userRoles              UserRole[]
  fieldDefinitions       FieldDefinition[]
  labelOverrides         LabelOverride[]
  pipelineDefinitions    PipelineDefinition[]
  integrationConfigs     IntegrationConfig[]
  integrationConnections IntegrationConnection[]
  userVerticals          UserVertical[]
  userBranches           UserBranch[]
  webhookSubscriptions   WebhookSubscription[]
  tenantPlugins          TenantPlugin[]
  tenantPlans            TenantPlan[]
  pageLayouts            PageLayout[]
  customObjectDefinitions CustomObjectDefinition[]
  flexRecords            FlexRecord[]
  automationWorkflows    AutomationWorkflow[]
  tenantExtensions       TenantExtension[]
  secureCredentials      SecureCredential[]
  leads                  Lead[]
  tasks                  Task[]
  notes                  Note[]
  productCategories      ProductCategory[]
  products               Product[]
  warehouses             Warehouse[]
  stock                  Stock[]
  stockMovements         StockMovement[]
  assets                 Asset[]
}

model Branch {
  id         String   @id @default(cuid())
  tenant_id  String
  name       String
  address    String?
  city       String?
  manager_id String?
  created_at DateTime @default(now())

  tenant    Tenant    @relation(fields: [tenant_id], references: [id])
  verticals    Vertical[]
  users        User[]        @relation("UserDefaultBranch")
  userBranches UserBranch[]
  batches      Batch[]
}

model Vertical {
  id         String   @id @default(cuid())
  tenant_id  String
  branch_id  String
  name       String
  created_at DateTime @default(now())

  tenant              Tenant              @relation(fields: [tenant_id], references: [id])
  branch              Branch              @relation(fields: [branch_id], references: [id])
  pipelineDefinitions PipelineDefinition[]
  campaigns           Campaign[]
  parties             Party[]
  leads               Lead[]
  userVerticals       UserVertical[]
  courses             Course[]

  @@unique([branch_id, name])
}

model User {
  id            String   @id @default(cuid())
  tenant_id     String
  branch_id     String?
  name          String
  email         String?
  phone_number  String?
  password_hash String
  status        String   @default("active")
  created_at    DateTime @default(now())

  tenant        Tenant       @relation(fields: [tenant_id], references: [id])
  branch        Branch?      @relation("UserDefaultBranch", fields: [branch_id], references: [id])
  userRoles     UserRole[]
  parties       Party[]
  appointments  Appointment[]
  leads         Lead[]
  userVerticals UserVertical[]
  userBranches  UserBranch[]
  callLogs      CallLog[]
  employees     Employee[]
  tasks         Task[]
  assets        Asset[]

  @@unique([email, tenant_id])
  @@unique([phone_number, tenant_id])
}

model UserBranch {
  id         String   @id @default(cuid())
  user_id    String
  branch_id  String
  tenant_id  String
  created_at DateTime @default(now())

  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branch_id], references: [id])
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([user_id, branch_id])
}

model UserVertical {
  id          String   @id @default(cuid())
  user_id     String
  vertical_id String
  tenant_id   String
  created_at  DateTime @default(now())

  user     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  vertical Vertical @relation(fields: [vertical_id], references: [id])
  tenant   Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([user_id, vertical_id])
}

model PlatformUser {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password_hash String
  status        String   @default("active")
  created_at    DateTime @default(now())

  platformUserRoles PlatformUserRole[]
}

model PlatformUserRole {
  id               String @id @default(cuid())
  platform_user_id String
  role             String

  platformUser PlatformUser @relation(fields: [platform_user_id], references: [id])

  @@unique([platform_user_id, role])
}

model RefreshToken {
  id         String    @id @default(cuid())
  user_id    String
  user_type  String
  token_hash String
  expires_at DateTime
  revoked_at DateTime?
  created_at DateTime  @default(now())

  @@index([token_hash])
  @@index([user_id])
}
