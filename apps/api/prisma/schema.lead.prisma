model Lead {
  id                 String   @id @default(cuid())
  tenant_id          String
  name               String
  email              String?
  phone              String
  source             String   // e.g. "facebook", "justdial", "web"
  status             String   @default("new") // e.g. "new", "contacted", "unqualified", "qualified", "converted"
  notes              String?
  campaign_id        String?
  assigned_to_id     String?
  converted_party_id String?
  converted_case_id  String?
  attributes         Json     @default("{}")
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  tenant             Tenant   @relation(fields: [tenant_id], references: [id])
  assigned_to        User?    @relation(fields: [assigned_to_id], references: [id])

  @@index([tenant_id, status])
  @@index([tenant_id, created_at])
  @@index([tenant_id, campaign_id])
  @@index([tenant_id, assigned_to_id])
}
